- content_for(:title, "Admin Login — Vocare Courses")

.min-h-screen.flex.items-center.justify-center.bg-gray-50.px-4
  .w-full.max-w-sm
    .text-center.mb-8
      %h1.text-2xl.font-bold.text-gray-900 Vocare Admin
      %p.text-sm.text-gray-500.mt-1 Log ind for at administrere kurset

    %div{ class: "bg-white rounded-2xl border border-gray-200 shadow-sm p-8" }
      = form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f|
        - if flash[:alert]
          %div{ class: "bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl text-sm mb-2" }
            = flash[:alert]

        %div
          = f.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-2"
          = f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "admin@vocare.dk", class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900"

        %div
          = f.label :password, "Adgangskode", class: "block text-sm font-medium text-gray-700 mb-2"
          = f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900"

        = f.hidden_field :remember_me, value: "1"

        = f.submit "Log ind", class: "w-full mt-4 bg-gray-900 hover:bg-gray-800 text-white font-semibold rounded-xl px-4 py-3 text-sm transition-colors cursor-pointer"

    .text-center.mt-6
      = link_to "← Tilbage til kurset", root_path, class: "text-sm text-gray-500 hover:text-gray-700"
