!!! 5
%html{ lang: "da" }
  %head
    %title= "Admin — Vocare Courses"
    %meta{ name: "viewport", content: "width=device-width,initial-scale=1" }
    = csrf_meta_tags
    = csp_meta_tag
    %link{ rel: "preconnect", href: "https://fonts.googleapis.com" }
    %link{ rel: "preconnect", href: "https://fonts.gstatic.com", crossorigin: true }
    %link{ rel: "stylesheet", href: "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" }
    = vite_client_tag
    = vite_javascript_tag "admin.jsx"

  %body.bg-gray-50.font-sans.antialiased.text-gray-900
    %nav.bg-white.border-b.border-gray-200
      %div{ class: "max-w-7xl mx-auto px-6 h-14 flex items-center justify-between" }
        .flex.items-center.gap-8
          %span.font-bold.text-lg.text-gray-900 Vocare Admin
          = link_to "Dashboard", admin_root_path, class: "text-sm text-gray-500 hover:text-gray-900 transition-colors"
          = link_to "Tokens", admin_tokens_path, class: "text-sm text-gray-500 hover:text-gray-900 transition-colors"
          = link_to "Kurser", admin_courses_path, class: "text-sm text-gray-500 hover:text-gray-900 transition-colors"
          = link_to "Kunder", admin_customers_path, class: "text-sm text-gray-500 hover:text-gray-900 transition-colors"
        .flex.items-center.gap-4
          %span.text-sm.text-gray-400= current_admin_user.email
          = link_to "Log ud", destroy_admin_user_session_path, data: { turbo_method: :delete }, class: "text-sm text-gray-400 hover:text-red-600 transition-colors"

    %div{ class: "max-w-7xl mx-auto px-6 py-8" }
      - if notice.present?
        %div{ class: "bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-xl mb-6 text-sm" }= notice
      - if alert.present?
        %div{ class: "bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-6 text-sm" }= alert
      = yield
