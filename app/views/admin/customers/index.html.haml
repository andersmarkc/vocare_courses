%h1.text-2xl.font-bold.mb-6 Kunder

%div{ class: "bg-white rounded-2xl border border-gray-200 overflow-hidden" }
  %table.w-full
    %thead
      %tr.border-b.border-gray-100
        %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Navn
        %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Email
        %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Virksomhed
        %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Token
        %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Oprettet
    %tbody
      - @customers.each do |customer|
        %tr{ class: "border-b border-gray-50 hover:bg-gray-50 transition-colors" }
          %td.px-5.py-4
            = link_to customer.name, admin_customer_path(customer), class: "text-sm text-gray-900 font-medium hover:underline"
          %td.px-5.py-4.text-sm.text-gray-500= customer.email || "—"
          %td.px-5.py-4.text-sm.text-gray-500= customer.company || "—"
          %td.px-5.py-4
            - if customer.token
              %span.font-mono.text-xs.text-gray-400= customer.token.code
          %td.px-5.py-4.text-sm.text-gray-400= customer.created_at.strftime("%d/%m/%Y")
