%h1.text-2xl.font-bold.mb-6 Kurser

%div{ class: "bg-white rounded-2xl border border-gray-200 overflow-hidden" }
  %table.w-full
    %thead
      %tr.border-b.border-gray-100
        %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Titel
        %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Sektioner
        %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Status
        %th.px-5.py-3
    %tbody
      - @courses.each do |course|
        %tr{ class: "border-b border-gray-50 hover:bg-gray-50 transition-colors" }
          %td.px-5.py-4
            = link_to course.title, admin_course_path(course), class: "text-sm text-gray-900 font-medium hover:underline"
          %td.px-5.py-4.text-sm.text-gray-500
            = pluralize(course.sections.size, "sektion", "sektioner")
          %td.px-5.py-4
            - if course.published?
              %span{ class: "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-600" } Publiceret
            - else
              %span{ class: "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-500" } Kladde
          %td.px-5.py-4.text-right
            = link_to "Vis", admin_course_path(course), class: "text-sm text-gray-500 hover:text-gray-900 transition-colors"
