%div{ class: "flex items-center justify-between mb-6" }
  .flex.items-center.gap-4
    %h1.text-2xl.font-bold= @section.title
    %span.text-sm.text-gray-400 Sektion #{@section.position}
  .flex.items-center.gap-3
    = link_to "Rediger", edit_admin_section_path(@section), class: "bg-gray-900 text-white px-4 py-2 rounded-xl text-sm font-medium hover:bg-gray-800 transition-colors"
    = link_to "← Tilbage til kursus", admin_course_path(@section.course), class: "text-sm text-gray-400 hover:text-gray-900 transition-colors"

- if @section.description.present?
  %div{ class: "text-sm text-gray-500 mb-6 rich-html" }= sanitize(@section.description, tags: HasRichText::ALLOWED_TAGS, attributes: HasRichText::ALLOWED_ATTRIBUTES)

-# Lessons
%div{ class: "flex items-center justify-between mb-4" }
  %h2.text-lg.font-semibold Lektioner
  = link_to "Tilføj lektion", new_admin_lesson_path(section_id: @section.id), class: "bg-gray-900 text-white px-4 py-2 rounded-xl text-sm font-medium hover:bg-gray-800 transition-colors"

- if @lessons.any?
  %div{ class: "bg-white rounded-2xl border border-gray-200 overflow-hidden" }
    %table.w-full
      %thead
        %tr.border-b.border-gray-100
          %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider.w-12 #
          %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Titel
          %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Type
          %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Varighed
          %th.px-5.py-3.text-right.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Handlinger
      %tbody
        - @lessons.each do |lesson|
          %tr{ class: "border-b border-gray-50 hover:bg-gray-50 transition-colors" }
            %td.px-5.py-4.text-sm.text-gray-400= lesson.position
            %td.px-5.py-4
              = link_to lesson.title, edit_admin_lesson_path(lesson), class: "text-sm text-gray-900 font-medium hover:underline"
            %td.px-5.py-4
              - case lesson.content_type
              - when "video"
                %span{ class: "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600" } Video
              - when "audio"
                %span{ class: "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600" } Audio
              - when "text"
                %span{ class: "inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-600" } Tekst
            %td.px-5.py-4.text-sm.text-gray-400
              - if lesson.duration_seconds.present? && lesson.duration_seconds > 0
                = "#{lesson.duration_seconds / 60} min"
              - else
                \—
            %td.px-5.py-4.text-right
              .flex.items-center.justify-end.gap-2
                - unless lesson == @lessons.first
                  = button_to "↑", move_admin_lesson_path(lesson, direction: "up"), method: :patch, class: "text-gray-400 hover:text-gray-900 px-2 py-1 rounded-lg hover:bg-gray-100 transition-colors text-sm"
                - unless lesson == @lessons.last
                  = button_to "↓", move_admin_lesson_path(lesson, direction: "down"), method: :patch, class: "text-gray-400 hover:text-gray-900 px-2 py-1 rounded-lg hover:bg-gray-100 transition-colors text-sm"
                = link_to "Rediger", edit_admin_lesson_path(lesson), class: "text-sm text-gray-500 hover:text-gray-900 transition-colors"
                = button_to "Slet", admin_lesson_path(lesson), method: :delete, class: "text-sm text-red-500 hover:text-red-700 transition-colors", data: { turbo_confirm: "Er du sikker?" }
- else
  %div{ class: "bg-white rounded-2xl border border-gray-200 p-8 text-center" }
    %p.text-gray-400 Ingen lektioner endnu

-# Facta boxes
%div{ class: "mt-10" }
  %div{ class: "flex items-center justify-between mb-4" }
    %h2.text-lg.font-semibold Faktabokse
    = link_to "Tilføj faktaboks", new_admin_section_facta_box_path(@section), class: "bg-gray-900 text-white px-4 py-2 rounded-xl text-sm font-medium hover:bg-gray-800 transition-colors"

  - if @facta_boxes.any?
    %div{ class: "bg-white rounded-2xl border border-gray-200 overflow-hidden" }
      %table.w-full
        %thead
          %tr.border-b.border-gray-100
            %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider.w-12 #
            %th.px-5.py-3.text-left.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Titel
            %th.px-5.py-3.text-right.text-xs.font-medium.text-gray-400.uppercase.tracking-wider Handlinger
        %tbody
          - @facta_boxes.each do |box|
            %tr{ class: "border-b border-gray-50 hover:bg-gray-50 transition-colors" }
              %td.px-5.py-4.text-sm.text-gray-400= box.position
              %td.px-5.py-4
                = link_to box.title, edit_admin_section_facta_box_path(@section, box), class: "text-sm text-gray-900 font-medium hover:underline"
              %td.px-5.py-4.text-right
                .flex.items-center.justify-end.gap-2
                  = link_to "Rediger", edit_admin_section_facta_box_path(@section, box), class: "text-sm text-gray-500 hover:text-gray-900 transition-colors"
                  = button_to "Slet", admin_section_facta_box_path(@section, box), method: :delete, class: "text-sm text-red-500 hover:text-red-700 transition-colors", data: { turbo_confirm: "Er du sikker?" }
  - else
    %div{ class: "bg-white rounded-2xl border border-gray-200 p-8 text-center" }
      %p.text-gray-400 Ingen faktabokse endnu

-# Quiz
%div{ class: "mt-8" }
  %div{ class: "flex items-center justify-between mb-4" }
    %h2.text-lg.font-semibold Quiz
    - unless @quiz
      = link_to "Opret quiz", new_admin_quiz_path(section_id: @section.id), class: "bg-gray-900 text-white px-4 py-2 rounded-xl text-sm font-medium hover:bg-gray-800 transition-colors"

  - if @quiz
    %div{ class: "bg-white rounded-2xl border border-gray-200 p-5" }
      %div{ class: "flex items-center justify-between" }
        %div
          = link_to @quiz.title, admin_quiz_path(@quiz), class: "font-medium text-gray-900 hover:underline"
          %p.text-sm.text-gray-400.mt-1
            = pluralize(@quiz.quiz_questions.size, "spørgsmål")
            %span.mx-1 ·
            Beståelsesscore: #{@quiz.passing_score}%
        .flex.items-center.gap-3
          = link_to "Vis", admin_quiz_path(@quiz), class: "text-sm text-gray-500 hover:text-gray-900 transition-colors"
          = link_to "Rediger", edit_admin_quiz_path(@quiz), class: "text-sm text-gray-500 hover:text-gray-900 transition-colors"
  - else
    %div{ class: "bg-white rounded-2xl border border-gray-200 p-8 text-center" }
      %p.text-gray-400 Ingen quiz endnu
