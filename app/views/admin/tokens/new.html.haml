%h1.text-2xl.font-bold.mb-6 Opret token

%div{ class: "bg-white rounded-2xl border border-gray-200 p-8 max-w-lg" }
  = form_with model: [:admin, @token], class: "space-y-5" do |f|
    %div
      = f.label :label, "Label (valgfrit)", class: "block text-sm font-medium text-gray-700 mb-2"
      = f.text_field :label, placeholder: "F.eks. CompanyX - seat 3", class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900"
    %div
      = f.label :expires_at, "Udløbsdato (valgfrit)", class: "block text-sm font-medium text-gray-700 mb-2"
      = f.datetime_local_field :expires_at, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900"
    .flex.items-center.gap-3.pt-2
      = f.submit "Opret token", class: "bg-gray-900 text-white px-5 py-3 rounded-xl text-sm font-medium hover:bg-gray-800 transition-colors cursor-pointer"
      = link_to "Annuller", admin_tokens_path, class: "px-5 py-3 rounded-xl text-sm text-gray-500 hover:text-gray-900 transition-colors"
