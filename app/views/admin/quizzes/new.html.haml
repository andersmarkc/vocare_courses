%div{ class: "flex items-center justify-between mb-6" }
  %h1.text-2xl.font-bold Ny quiz
  - if @quizzable.is_a?(Section)
    = link_to "← Tilbage", admin_section_path(@quizzable), class: "text-sm text-gray-400 hover:text-gray-900 transition-colors"
  - else
    = link_to "← Tilbage", admin_course_path(@quizzable), class: "text-sm text-gray-400 hover:text-gray-900 transition-colors"

%div{ class: "bg-white rounded-2xl border border-gray-200 p-6 max-w-2xl" }
  = form_with model: [:admin, @quiz], class: "space-y-5" do |f|
    = f.hidden_field :quizzable_type, value: @quizzable.class.name
    = f.hidden_field :quizzable_id, value: @quizzable.id

    - if @quiz.errors.any?
      %div{ class: "bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm" }
        %ul.list-disc.list-inside
          - @quiz.errors.full_messages.each do |msg|
            %li= msg

    %div
      = f.label :title, "Titel", class: "block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2"
      = f.text_field :title, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900"

    %div
      = f.label :description, "Beskrivelse", class: "block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2"
      = f.text_area :description, rows: 3, class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900"

    %div
      = f.label :passing_score, "Beståelsesscore (%)", class: "block text-xs font-medium text-gray-400 uppercase tracking-wider mb-2"
      = f.number_field :passing_score, min: 0, max: 100, class: "w-24 border border-gray-200 rounded-xl px-4 py-3 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-gray-900"

    %div{ class: "flex items-center gap-3 pt-2" }
      = f.submit "Opret", class: "bg-gray-900 text-white px-6 py-2 rounded-xl text-sm font-medium hover:bg-gray-800 transition-colors cursor-pointer"
      - if @quizzable.is_a?(Section)
        = link_to "Annuller", admin_section_path(@quizzable), class: "text-sm text-gray-400 hover:text-gray-900 transition-colors"
      - else
        = link_to "Annuller", admin_course_path(@quizzable), class: "text-sm text-gray-400 hover:text-gray-900 transition-colors"
